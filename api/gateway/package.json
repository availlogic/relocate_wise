{
  "name": "@relocatewise/gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "npm run -w @relocatewise/shared build",
    "build": "tsc -p tsconfig.build.json",
    "predev": "npm run -w @relocatewise/shared build",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "pretest": "npm run -w @relocatewise/shared build",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "npm run -w @relocatewise/shared build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@relocatewise/shared": "*",
    "fastify": "^4.28.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}