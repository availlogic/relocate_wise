# Default credentials for local development. Production must override
# these via a real .env or Docker secret.

POSTGRES_USER=relocatewise
POSTGRES_PASSWORD=relocatewise
POSTGRES_DB=relocatewise

# CORS allow-list for the Fastify API. Comma-separated, or empty to
# echo any origin (dev only). In production this is the Cloudflare
# Pages domain (e.g. https://relocatewise.pages.dev or a custom
# https://example.com). The Cloudflare Tunnel layer guarantees the
# edge only ever originates the trusted Origin.
CORS_ORIGIN=http://localhost:5173

# Git SHA returned by /api/health. Set at deploy time.
GIT_SHA=dev

# Cloudflare Pages routing for /api/* happens at the edge tier (Pages
# Functions → Cloudflare Tunnel → Caddy). The SPA uses relative
# `/api/*` URLs, so no SPA-side env var is required. If you want to
# point the SPA at a different API host (e.g. for a staging env),
# set VITE_API_BASE at build time:
# VITE_API_BASE=https://staging.example.com

# Rate-limit on the API side (Architecture §11). When set to "1" the
# server installs @fastify/rate-limit at 100 req/min/IP. The
# Cloudflare Edge tier rate-limits at 60 req / 10 min / IP for the
# browser-facing ingress.
# ENABLE_RATE_LIMIT=1

# Ingestion pipeline scheduling (PRD FR-16). Default runs monthly.
# Set INGESTION_DISABLED=1 for read-only environments.
# INGESTION_CRON=0 3 1 * *