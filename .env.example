# Default credentials for local development. Production must override
# these via a real .env or Docker secret.

POSTGRES_USER=relocatewise
POSTGRES_PASSWORD=relocatewise
POSTGRES_DB=relocatewise

# CORS allow-list for the Fastify API. Comma-separated, or empty to
# echo any origin (dev only). The Netlify function proxy sends the
# same Origin it was invoked with, so this is the only place the
# policy needs to live.
CORS_ORIGIN=http://localhost:5173

# Git SHA returned by /api/health. Set at deploy time.
GIT_SHA=dev
