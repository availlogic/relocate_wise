# Default credentials for local development. Production must override
# these via a real .env or Docker secret.

POSTGRES_USER=relocatewise
POSTGRES_PASSWORD=relocatewise
POSTGRES_DB=relocatewise

# CORS allow-list for the Fastify API. Comma-separated, or empty to
# echo any origin (dev only). The Netlify function proxy sends the
# same Origin it was invoked with, so this is the only place the
# policy needs to live.
CORS_ORIGIN=http://localhost:5173

# Git SHA returned by /api/health. Set at deploy time.
GIT_SHA=dev

# Shared secret for the Netlify edge proxy → backend hop
# (Architecture §11). When set, all /api/* requests except /api/health
# must carry the matching `x-relocatewise-secret` header. Leave
# commented out in local dev so the dev workflow keeps working.
# API_SECRET=

# Rate-limit on the API side (Architecture §11). When set to "1" the
# server installs @fastify/rate-limit at 100 req/min/IP. The Netlify
# edge tier already rate-limits (60 req / 10 min / IP), so this is
# belt-and-suspenders for direct-to-API traffic.
# ENABLE_RATE_LIMIT=1