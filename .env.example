# Default credentials for local development. Production must override
# these via a real .env or Docker secret.

POSTGRES_USER=relocatewise
POSTGRES_PASSWORD=relocatewise
POSTGRES_DB=relocatewise

# Schema-segregated connection pools (Phase A, v1.0.0 GA).
# `docker-compose.yml` exports the three URLs below into the api
# service. They map to three distinct PostgreSQL roles provisioned by
# `db/migrations/003_schemas.sql`:
#
#   * ADMIN_DATABASE_URL       — `POSTGRES_USER` (superuser). Used by
#                                the migration runner + boot seed only.
#   * MATCHING_DATABASE_URL    — `matching_service` role. R/W on
#                                `matching.*`; SELECT-only on
#                                `ingestion.*`. Used by every HTTP
#                                request handler.
#   * INGESTION_DATABASE_URL   — `ingestion_service` role. SELECT-only
#                                on `matching.*`; R/W on
#                                `ingestion.*`. Used by the ingestion
#                                pipeline.
#
# Defaults match `docker-compose.yml`. Override per-environment via
# Docker secrets or your platform's secret store.
ADMIN_DATABASE_URL=postgres://relocatewise:relocatewise@db:5432/relocatewise
DATABASE_URL=postgres://relocatewise:relocatewise@db:5432/relocatewise
MATCHING_DATABASE_URL=postgres://matching_service:matching_service@db:5432/relocatewise
INGESTION_DATABASE_URL=postgres://ingestion_service:ingestion_service@db:5432/relocatewise

# CORS allow-list for the Fastify API. Comma-separated, or empty to
# echo any origin (dev only). In production this is the Cloudflare
# Pages domain (e.g. https://relocatewise.pages.dev or a custom
# https://example.com). The Cloudflare Tunnel layer guarantees the
# edge only ever originates the trusted Origin.
CORS_ORIGIN=http://localhost:5173

# Git SHA returned by /api/health. Set at deploy time.
GIT_SHA=dev

# Cloudflare Pages routing for /api/* happens at the edge tier (Pages
# Functions → Cloudflare Tunnel → Caddy). The SPA uses relative
# `/api/*` URLs, so no SPA-side env var is required. If you want to
# point the SPA at a different API host (e.g. for a staging env),
# set VITE_API_BASE at build time:
# VITE_API_BASE=https://staging.example.com

# Rate-limit on the API side (Architecture §11). When set to "1" the
# server installs @fastify/rate-limit at 100 req/min/IP. The
# Cloudflare Edge tier rate-limits at 60 req / 10 min / IP for the
# browser-facing ingress.
# ENABLE_RATE_LIMIT=1

# Ingestion pipeline scheduling (PRD FR-16). Default runs monthly.
# Set INGESTION_DISABLED=1 for read-only environments.
# INGESTION_CRON=0 3 1 * *

# Internal sync endpoint target (Phase C, v1.0.0 GA). The ingestion
# service PUTs each dimension's score to the matching service's internal
# endpoint over HTTP. In single-container setups the matching service is
# reachable on localhost; in the post-Phase-B deployment the gateway
# fronts the matching service and the URL points at the gateway.
#
# INGESTION_TARGET_TOKEN must match the matching service's API_SECRET.
# When either variable is unset the ingestion pipeline falls back to
# a no-op writer — useful for read-only staging environments.
# INGESTION_TARGET_URL=http://localhost:3000
# INGESTION_TARGET_TOKEN=<your-api-secret>