{
  "name": "@relocatewise/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run -w @relocatewise/shared build",
    "dev": "vite",
    "prebuild": "npm run -w @relocatewise/shared build",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "pretest": "npm run -w @relocatewise/shared build",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretypecheck": "npm run -w @relocatewise/shared build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@netlify/functions": "^5.3.0",
    "@relocatewise/shared": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.11.1",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
