# RelocateWise — Caddy reverse proxy in front of the Fastify API.
#
# In production the API is exposed via Cloudflare Tunnel
# (`docker-compose.cloudflared.yml`); cloudflared tunnels all HTTPS
# traffic from Cloudflare's edge to this container over the
# internal Docker network. No inbound ports are opened on the host
# firewall — Caddy is reached only on the Docker network.
#
# Architecture references: §2 (topology), §10.3 (deploy), §11 (TLS).
#
# In local dev, uncomment the bottom block and run with
# `caddy run --config Caddyfile` inside the container. Caddy
# generates a self-signed cert via `tls internal`.

# ----- Production (internal Docker network only) -----
:80 {
    encode gzip zstd
    reverse_proxy api:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }
    log {
        output stdout
        format console
    }
}

# ----- Local dev -----
# Uncomment the block below to run with a self-signed cert at
# https://localhost. Browsers will warn; that's expected in dev.
#
# https://localhost {
#     tls internal
#     reverse_proxy api:3000
# }