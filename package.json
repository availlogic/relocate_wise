{
  "name": "relocatewise",
  "version": "0.1.0",
  "private": true,
  "description": "RelocateWise — a web-based decision-support tool for relocation.",
  "workspaces": [
    "shared",
    "api/matching-service",
    "api/ingestion-service",
    "api/gateway",
    "web/container",
    "web/quiz-mfe",
    "web/compare-mfe",
    "web/dashboard-mfe"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "vitest": "^2.1.2"
  }
}